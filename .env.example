# Supabase (required on Vercel for live data)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: direct Postgres for local seed scripts
SUPABASE_DB_URL=postgresql://postgres.your-project:password@aws-0-region.pooler.supabase.com:5432/postgres

# Optional: server-side cache TTL in milliseconds (default 300000)
# WORLDCUP_DB_CACHE_TTL_MS=300000
